rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Phase 3: Primitive Definition
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    // Enforce email_verified, unless we allow anonymous testing. Let's allow isSignedIn if auth != null, 
    // but in production we'd want request.auth.token.email_verified == true. 
    // Using standard isSignedIn to avoid locking out test Google accounts if they aren't verified by default in sandbox.
    function isSignedIn() { return request.auth != null; }
    
    function isValidTransaction(data) {
      return data.keys().hasAll(['date', 'desc', 'cat', 'type', 'amount', 'source', 'userId', 'createdAt', 'updatedAt']) &&
             data.size() >= 9 && data.size() <= 60 &&
             data.date is string && data.date.size() <= 20 &&
             data.desc is string && data.desc.size() <= 200 &&
             data.cat is string && data.cat.size() <= 100 &&
             data.type is string && (data.type == 'Receita' || data.type == 'Despesa') &&
             data.amount is number &&
             data.source is string && data.source.size() <= 100 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.createdAt is timestamp && data.updatedAt is timestamp &&
             (!data.keys().hasAny(['recognitionConfidence']) || (data.recognitionConfidence is number && data.recognitionConfidence >= 0.0 && data.recognitionConfidence <= 1.0)) &&
             (!data.keys().hasAny(['recognitionMethod']) || (data.recognitionMethod is string && data.recognitionMethod.size() <= 100)) &&
             (!data.keys().hasAny(['recognitionEvidence']) || (data.recognitionEvidence is list && data.recognitionEvidence.size() <= 50)) &&
             (!data.keys().hasAny(['needsReview']) || data.needsReview is bool) &&
             (!data.keys().hasAny(['aiUsed']) || data.aiUsed is bool) &&
             (!data.keys().hasAny(['aiReason']) || (data.aiReason is string && data.aiReason.size() <= 500)) &&
             (!data.keys().hasAny(['merchantKey']) || (data.merchantKey is string && data.merchantKey.size() <= 200)) &&
             (!data.keys().hasAny(['cleanDescription']) || (data.cleanDescription is string && data.cleanDescription.size() <= 300));
    }
    
    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'highSpendingAlerts', 'createdAt', 'updatedAt']) &&
             data.size() >= 4 && data.size() <= 11 &&
             (!data.keys().hasAny(['categories']) || (data.categories is list && data.categories.size() <= 100 && (data.categories.size() == 0 || data.categories[0] is string))) &&
             (!data.keys().hasAny(['darkMode']) || data.darkMode is bool) &&
             (!data.keys().hasAny(['phone']) || (data.phone is string && data.phone.size() <= 20)) &&
             (!data.keys().hasAny(['pluggyClientIdMasked']) || (data.pluggyClientIdMasked is string && data.pluggyClientIdMasked.size() <= 100)) &&
             (!data.keys().hasAny(['pluggyCredentialsConfigured']) || data.pluggyCredentialsConfigured is bool) &&
             (!data.keys().hasAny(['pluggyItemIds']) || (data.pluggyItemIds is list && data.pluggyItemIds.size() <= 100 && (data.pluggyItemIds.size() == 0 || data.pluggyItemIds[0] is string))) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.highSpendingAlerts is bool &&
             data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function isValidAccountBalance(data) {
      return data.keys().hasAll([
        'userId', 'provider', 'accountId', 'bankName', 'accountName', 
        'accountLabel', 'accountType', 'balance', 'includeInSaldoTotal', 
        'includeReason', 'lastSyncedAt', 'createdAt', 'updatedAt'
      ]) &&
             data.size() >= 13 && data.size() <= 25 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.provider is string && (data.provider == 'pluggy' || data.provider == 'manual') &&
             data.accountId is string && data.accountId.size() <= 128 &&
             data.bankName is string && data.bankName.size() <= 100 &&
             data.accountName is string && data.accountName.size() <= 100 &&
             data.accountLabel is string && data.accountLabel.size() <= 100 &&
             data.accountType is string && data.accountType.size() <= 100 &&
             data.balance is number &&
             data.includeInSaldoTotal is bool &&
             data.includeReason is string && data.includeReason.size() <= 200 &&
             data.lastSyncedAt is timestamp &&
             data.createdAt is timestamp && data.updatedAt is timestamp &&
             (!data.keys().hasAny(['itemId']) || (data.itemId is string && data.itemId.size() <= 128)) &&
             (!data.keys().hasAny(['bankRawName']) || (data.bankRawName is string && data.bankRawName.size() <= 100)) &&
             (!data.keys().hasAny(['accountRawName']) || (data.accountRawName is string && data.accountRawName.size() <= 100)) &&
             (!data.keys().hasAny(['accountSubtype']) || (data.accountSubtype is string && data.accountSubtype.size() <= 100)) &&
             (!data.keys().hasAny(['number']) || (data.number is string && data.number.size() <= 50)) &&
             (!data.keys().hasAny(['currencyCode']) || (data.currencyCode is string && data.currencyCode.size() <= 10)) &&
             (!data.keys().hasAny(['status']) || (data.status is string && data.status.size() <= 50)) &&
             (!data.keys().hasAny(['sourceRaw']) || (data.sourceRaw is string && data.sourceRaw.size() <= 200));
    }

    function isValidLearnedRule(data) {
      return data.keys().hasAll(['userId', 'merchantKey', 'category', 'cleanDescription', 'type', 'createdAt', 'updatedAt']) &&
             data.size() == 7 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.merchantKey is string && data.merchantKey.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.cleanDescription is string && data.cleanDescription.size() <= 200 &&
             data.type is string && (data.type == 'Receita' || data.type == 'Despesa') &&
             data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    match /transactions/{transactionId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid && isValidId(transactionId);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid && isValidId(transactionId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if (
        isSignedIn() && 
        isValidId(transactionId) && 
        isValidTransaction(incoming()) && 
        incoming().createdAt == request.time && 
        incoming().updatedAt == request.time
      );
      
      allow update: if (
        isSignedIn() && 
        isValidId(transactionId) && 
        isValidTransaction(incoming()) && 
        existing().userId == request.auth.uid && 
        incoming().userId == existing().userId && 
        incoming().createdAt == existing().createdAt && 
        incoming().updatedAt == request.time && 
        incoming().diff(existing()).affectedKeys().hasOnly([
          'date', 'desc', 'cat', 'type', 'amount', 'source', 'updatedAt',
          'rawAmount', 'sourceRaw', 'bankRawName', 'accountRawName', 'accountLabel',
          'accountId', 'itemId', 'pluggyType', 'accountType', 'accountSubtype',
          'operationType', 'paymentData', 'merchant', 'descriptionRaw', 'detectedDirection',
          'directionConfidence', 'directionReason', 'isLikelyInternalTransfer', 'shouldIgnoreInTotals', 'pluggyId',
          'recognitionConfidence', 'recognitionMethod', 'recognitionEvidence', 'needsReview', 'aiUsed', 'aiReason', 'merchantKey', 'cleanDescription'
        ])
      );
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid && isValidId(userId) && userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if (
        isSignedIn() && 
        isValidId(userId) && 
        userId == request.auth.uid && 
        isValidUserProfile(incoming()) && 
        incoming().createdAt == request.time && 
        incoming().updatedAt == request.time
      );
      
      allow update: if (
        isSignedIn() && 
        isValidId(userId) && 
        userId == request.auth.uid && 
        isValidUserProfile(incoming()) && 
        existing().userId == request.auth.uid && 
        incoming().userId == existing().userId && 
        incoming().createdAt == existing().createdAt && 
        incoming().updatedAt == request.time && 
        incoming().diff(existing()).affectedKeys().hasOnly([
          'highSpendingAlerts', 'categories', 'darkMode', 'phone', 
          'pluggyClientIdMasked', 'pluggyCredentialsConfigured', 
          'pluggyItemIds', 'updatedAt'
        ])
      );

      match /secrets/{secretId} {
        allow read, write: if false;
      }

      match /learnedRules/{ruleId} {
        allow get: if isSignedIn() && userId == request.auth.uid && isValidId(ruleId);
        allow delete: if isSignedIn() && userId == request.auth.uid && isValidId(ruleId);
        allow list: if isSignedIn() && userId == request.auth.uid;
        
        allow create: if (
          isSignedIn() && 
          userId == request.auth.uid && 
          isValidId(ruleId) && 
          isValidLearnedRule(incoming()) && 
          incoming().createdAt == request.time && 
          incoming().updatedAt == request.time
        );
        
        allow update: if (
          isSignedIn() && 
          userId == request.auth.uid && 
          isValidId(ruleId) && 
          isValidLearnedRule(incoming()) && 
          existing().userId == request.auth.uid && 
          incoming().userId == existing().userId && 
          incoming().createdAt == existing().createdAt && 
          incoming().updatedAt == request.time && 
          incoming().diff(existing()).affectedKeys().hasOnly(['category', 'cleanDescription', 'type', 'updatedAt'])
        );
      }
    }

    match /accountBalances/{balanceId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid && isValidId(balanceId);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid && isValidId(balanceId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if (
        isSignedIn() && 
        isValidId(balanceId) && 
        isValidAccountBalance(incoming()) && 
        incoming().createdAt == request.time && 
        incoming().updatedAt == request.time
      );
      
      allow update: if (
        isSignedIn() && 
        isValidId(balanceId) && 
        isValidAccountBalance(incoming()) && 
        existing().userId == request.auth.uid && 
        incoming().userId == existing().userId && 
        incoming().createdAt == existing().createdAt && 
        incoming().updatedAt == request.time && 
        incoming().diff(existing()).affectedKeys().hasOnly([
          'balance', 'includeInSaldoTotal', 'includeReason', 'lastSyncedAt', 'updatedAt',
          'bankName', 'bankRawName', 'accountName', 'accountRawName', 'accountLabel',
          'accountType', 'accountSubtype', 'number', 'currencyCode', 'status', 'sourceRaw', 'raw'
        ])
      );
    }
  }
}

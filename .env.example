# GEMINI_API_KEY is optional for self-hosted development only.
# Public/free deployments should use per-user AI keys stored in users/{uid}/secrets/ai.
# It must not be used as a public fallback unless AI_GLOBAL_FALLBACK_ENABLED=true.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Enables factual Gemini mock responses only in development.
# Never enable this in production.
ENABLE_SIMULATED_AI_FALLBACK=false

# Optional secret used to validate Pluggy webhook callbacks.
# Configure the same value as a custom header when creating webhooks.
PLUGGY_WEBHOOK_SECRET=

# Pluggy integration uses per-user credentials saved in users/{uid}/secrets/pluggy.
# Global Pluggy credentials are not used.

# IA desativada por padrão.
# Usuários poderão configurar suas próprias chaves de IA no app.
# Chaves globais não devem ser fallback público.
# AI is disabled by default. Users can configure their own AI provider and API key in the app. Global AI fallback is disabled.
AI_GLOBAL_FALLBACK_ENABLED=false

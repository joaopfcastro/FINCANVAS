# FINCANVAS Environment Example
# Copy this file to .env.local or configure these variables in your hosting provider.

# App public URL.
# Used for OAuth callbacks, webhook URLs and self-referential API links.
APP_URL="MY_APP_URL"

# AI is disabled by default.
# Users can configure their own AI provider and API key in the app.
# Public/free deployments should use per-user AI keys stored in users/{uid}/secrets/ai.
# GEMINI_API_KEY is optional for self-hosted development only.
# It must not be used as a public fallback unless AI_GLOBAL_FALLBACK_ENABLED=true.
GEMINI_API_KEY=

# Global AI fallback is disabled by default.
AI_GLOBAL_FALLBACK_ENABLED=false

# Enables factual Gemini mock responses only in development.
# Nunca habilitar em produção. Use apenas em sandbox/desenvolvimento quando APIs externas estiverem indisponíveis.
ENABLE_SIMULATED_AI_FALLBACK=false

# Optional secret used to validate Pluggy webhook callbacks.
# Configure the same value as a custom header when creating webhooks.
PLUGGY_WEBHOOK_SECRET=

# Firebase Admin credential variables (Phase 1)
# GOOGLE_APPLICATION_CREDENTIALS must be the absolute path to your Firebase service account JSON file.
# FIREBASE_SERVICE_ACCOUNT_JSON must contain the entire, inline JSON string of your Firebase service account key.
# Tip: In sandbox or cloud environments like Google AI Studio, using FIREBASE_SERVICE_ACCOUNT_JSON is highly recommended and more practical.
# WARNING: Do not commit your service account file or keys to GitHub or public repositories.
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=

# AI Provider custom configurations (Phase 3)
# Max execution/test connection timeout in milliseconds. Must be a positive integer. Default is 30000.
AI_PROVIDER_TEST_TIMEOUT_MS=30000

# Pluggy integration uses per-user credentials saved in users/{uid}/secrets/pluggy.
# Global Pluggy credentials are not used.